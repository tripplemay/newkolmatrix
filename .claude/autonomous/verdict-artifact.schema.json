{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "verdict-artifact",
  "description": "autonomous-mode.md 机件 #3 的验收工件 schema。verify 每轮必产 docs/test-reports/{BL-id}-verdict.json，喂沉淀引擎（§8.4）。存在≠真实：每 feature 的 evidence / steps_to_reproduce 必须非空，机械拒收空壳 PASS。",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch_id", "fix_round", "created_at", "verdicts"],
  "properties": {
    "batch_id": { "type": "string", "description": "= progress.json.current_sprint（BL-id）" },
    "fix_round": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["feature_id", "result", "evidence", "steps_to_reproduce"],
        "properties": {
          "feature_id": { "type": "string" },
          "result": { "type": "string", "enum": ["PASS", "PARTIAL", "FAIL"] },
          "evidence": { "type": "string", "minLength": 1, "description": "实测证据（测试输出/命令/staging 结果），非空——空 = 空壳，拒收" },
          "steps_to_reproduce": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
