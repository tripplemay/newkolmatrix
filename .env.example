# newkolmatrix 环境变量模板。复制为 .env 使用。真实 secret 绝不入 git（.env 已 gitignore）。
# 本机 dev 用下方 DATABASE_URL + AIGCGATEWAY_*；生产 deploysvr 见文末「生产部署」段。

# 反向代理子路径部署时设置（如 /app）；根路径部署留空。
NEXT_PUBLIC_BASE_PATH=

# 关闭 Next telemetry（可选，Dockerfile/CI 已设）
NEXT_TELEMETRY_DISABLED=1

# --- AGENT-FOUNDATION F002：数据库（Prisma + Postgres 16 + pgvector）---
# 本地 dev：先 `docker compose -f docker-compose.dev.yml up -d` 起库，再复制本文件为 .env。
# 下面是本机 dev throwaway 凭据（只对 localhost 容器有效，非生产 secret）；
# 真实生产 DATABASE_URL 走部署环境注入，绝不入 git。
DATABASE_URL=postgresql://kol:kol_dev_password@localhost:5434/kolmatrix?schema=public

# 覆盖 docker-compose.dev.yml 默认凭据时可设（未设则用 compose 内 dev 默认值）
# POSTGRES_USER=kol
# POSTGRES_PASSWORD=kol_dev_password
# POSTGRES_DB=kolmatrix

# --- AGENT-FOUNDATION F003：aigcgateway（Vercel AI SDK 模型出口）---
# 网关 OpenAI 兼容端点 + API key。真实 key 绝不入 git（.env 已 gitignore）。
# 在 aigcgateway 控制台创建 key 后填入 .env。
AIGCGATEWAY_BASE_URL=https://aigc.guangai.ai/v1
AIGCGATEWAY_API_KEY=pk_your_key_here
# 可选覆盖（未设则用代码默认：chat=deepseek-v3 / embedding=bge-m3 / timeout=15s / max_tokens=2000）
# 注意：模型须在网关项目已配 active channel（gpt-4o-mini 等未配会 503 No active channel）
# AIGCGATEWAY_CHAT_MODEL=deepseek-v3
# AIGCGATEWAY_EMBEDDING_MODEL=bge-m3
# AIGC_TIMEOUT_MS=15000
# AIGC_MAX_OUTPUT_TOKENS=2000

# --- M1-D-KNOWLEDGE F006：素材上传 / 解析（knowledge 域）---
# 素材文件根目录（U2 本地盘通道）：dev 默认 ./.materials（gitignore）；
# 生产 compose 挂卷 /app/materials（newkolmatrix-materials），无需手设。
# MATERIALS_DIR=./.materials
# 图片解析 vision 模型（P4 路由；默认 qwen3.5-flash——网关项目须已配 active channel）
# AIGCGATEWAY_VISION_MODEL=qwen3.5-flash
# 上传 rate-limit 关断阀（P8 fail-open 之外的显式 escape，压测/验收用）
# DISABLE_UPLOAD_RATELIMIT=1

# --- M2-B-CREATORS F001：apify-kol 外采服务（拉模型只读，P1 零投喂）---
# 服务在 deploysvr 内网（kol-shared 网络别名 apify-kol:3003），本地 dev 不可达属预期
#（kol-sync 例程探活失败静默跳过）。L2 实测走 ssh 隧道：
#   ssh -L 3004:localhost:3004 deploysvr   → APIFY_KOL_BASE_URL=http://localhost:3004
# key = apify-kol 服务的 BUSINESS_API_KEY（只读 /kol*；服务器 /opt/apps/apify-kol-service/.env）
# APIFY_KOL_BASE_URL=http://localhost:3004
# APIFY_KOL_API_KEY=your_business_key_here
# APIFY_KOL_TIMEOUT_MS=10000

# ===== 生产部署（deploysvr /opt/apps/newkolmatrix/.env，GO-LIVE F001）=====
# docker-compose.prod.yml 用同目录 .env 做变量插值（绝不入 git）。人工在服务器创建，只放下面几项：
#   POSTGRES_PASSWORD=<强随机口令>            # db 容器口令 + 派生 DATABASE_URL 的单一来源
#   AIGCGATEWAY_API_KEY=<真实网关 key>        # 生产网关 key
# 可选：
#   POSTGRES_USER=kol                         # 默认 kol
#   POSTGRES_DB=kolmatrix                     # 默认 kolmatrix
#   AIGCGATEWAY_BASE_URL=https://aigc.guangai.ai/v1
#   IMAGE_TAG=latest                          # 或某 git SHA（回滚用）
# DATABASE_URL 无需手写：compose 由 POSTGRES_* 派生指向容器网内 db 服务（postgresql://kol:***@db:5432/kolmatrix）。

# --- M3-A-REACH-CRM F003/F004/F010：触达域（Resend 真投递 + webhook）---
# 本地 dev 默认全不配 = MockEmailSender（SENT_MARKER 不外呼）；配真 key 即真发（P1：仅测试邮箱）。
# 生产（deploysvr .env 追加，deploy.md M3-A 前置人工步）：
#   RESEND_API_KEY=<服务器侧自 /opt/apps/kolmatrix/.env 复制——U2 复用，密钥不离 VPS>
#   RESEND_WEBHOOK_SECRET=<Resend 控制台新建 newkol endpoint 后签发的 signing secret（不可复制旧项目值）>
#   OUTREACH_TEST_RECIPIENT=<自有测试邮箱——验收真发唯一许可目标（P1）>
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# OUTREACH_TEST_RECIPIENT=
# DISABLE_GATE_RATELIMIT=true                 # P9 escape hatch（压测/本地调试；生产勿开）
