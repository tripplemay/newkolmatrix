{
  "name": "kolmatrix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots=all",
    "postinstall": "prisma generate",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "prisma migrate deploy",
    "db:smoke": "node --env-file=.env --import tsx scripts/test/db-smoke.ts",
    "ai:smoke": "node --env-file=.env --import tsx scripts/test/ai-gateway-smoke.ts",
    "seed:kol": "node --env-file=.env --import tsx scripts/seed/import-kol-csv.ts",
    "agent:smoke": "node --env-file=.env --import tsx scripts/test/agent-tools-smoke.ts",
    "orch:smoke": "node --env-file=.env --import tsx scripts/test/orchestration-smoke.ts",
    "seed:demo-handoff": "node --env-file=.env --import tsx scripts/seed/demo-handoff.ts",
    "f007:browser": "node scripts/test/f007-browser-check.mjs",
    "f008:browser": "node scripts/test/f008-browser-check.mjs",
    "gate:smoke": "node --env-file=.env --import tsx scripts/test/gate-smoke.ts",
    "f010:e2e": "node --env-file=.env --import tsx scripts/seed/demo-handoff.ts && node scripts/test/f010-e2e-check.mjs",
    "p2:f001": "node scripts/test/p2-cleanup-f001-drawer-close.mjs",
    "p2:f002": "node scripts/test/p2-cleanup-f002-colormode-persist.mjs",
    "p2:f003": "node scripts/test/p2-cleanup-f003-avatar-colormode.mjs",
    "p2:f004": "node scripts/test/p2-cleanup-f004-handoff-panel.mjs"
  },
  "dependencies": {
