// AGENT-FOUNDATION F002 — 核心 schema（单角色）+ 运行时表（闸门 + 交接）
//
// 设计契约（权威：docs/specs/AGENT-FOUNDATION-spec.md §F002 + PRD §11 + 架构稿 §7.2）：
// - 单租户（D4）：Tenant 占位，硬编码 dev tenant；真实认证 / 多租户 RLS 留 M5（本批不建 RLS policy）
// - 单角色（D26）：User 无 role / scope / 权限字段
// - D29：业务实体带 owner 标记（String? = Leo/Ada/Kai）——是分工不是权限，非枚举非权限
// - D15：Kol 预留数据层字段契约位（audienceDemo/credibility/brandSafety/dataSource/fieldProvenance），本批 nullable 不填充
// - D3：pgvector 经自定义 SQL migration（CREATE EXTENSION IF NOT EXISTS vector），不用 Prisma postgresqlExtensions 预览开关；
//       Kol.embedding = Unsupported("vector(1024)")（Prisma 无原生 vector 类型，向量读写走 raw SQL，F004/F005）
// - D-INTEROP（§3.3）：核心实体（Kol/Project/Game/Tenant）带稳定对外标识 publicId/slug——为 GEO / 外部 agent 友好留插座；
//       fieldProvenance/dataSource 兼作对外可信层（provenance）。JSON-LD / GEO 具体字段 = EXTENSION POINT，本批不实装、不猜字段。
// - 三运行时表：PendingAction（F009 闸门落点）/ OperationLog（留痕）/ Handoff（F006 编排交接落点，架构稿 §5.4）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── 租户 / 用户（单租户 · 单角色）─────────────────────────

/// 租户占位表。本批单租户（硬编码 dev tenant），真实多租户 / RLS → M5。
model Tenant {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique // D-INTEROP 人类可读稳定标识
  name      String?
  createdAt DateTime @default(now())

  users    User[]
  kols     Kol[]
  projects Project[]
  games    Game[]
}

/// 单 dev 用户。D26：无 role / scope / 权限字段（三角色作废）。
model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ───────────────────────── 核心业务实体 ─────────────────────────

/// KOL 核心实体。含向量列 + D15 字段契约位（nullable）+ D29 owner + D-INTEROP 稳定标识。
model Kol {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识（未来 MCP / GEO 引用锚点）
  tenantId String

  /// F004 幂等 upsert 键：规范化后的唯一 handle
  canonicalHandle String

  // 核心字段（F004 CSV seed 填充；多数 nullable 以容忍 CSV 差异）
  displayName    String?
  platform       String? // youtube / twitch / tiktok / instagram
  handle         String?
  profileUrl     String?
  avatarUrl      String?
  country        String?
  language       String?
  followers      Int?
  avgViews       Int?
  engagementRate Float?
  categories     String[] @default([])
  bio            String?

  /// pgvector 向量列（bge-m3 1024 维，D3）。Unsupported → 读写走 raw SQL（F004 灌向量 / F005 cosine 检索）。
  embedding Unsupported("vector(1024)")?

  // ── D15 数据层字段契约位（本批 nullable 不填充；让数据层与应用层解耦）──
  // 兼作 D-INTEROP provenance 对外可信层（GEO 时代 AI 引擎最看重「有出处、可信」）。
  audienceDemo    Json?   // 受众画像
  credibility     Json?   // 可信度评估（结构留扩展点，第三方评估 API → M5）
  brandSafety     Json?   // 品牌安全评估
  dataSource      String? // 数据来源（架构稿 §7.5：按真实证据填写）
  fieldProvenance Json?   // 逐字段出处（provenance）

  /// D29 分工标记（Leo/Ada/Kai）——是分工不是权限，非枚举非权限。
  owner String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planKols        PlanKol[] // M2-A F001：入选组合的反向关系
  matchCandidates MatchCandidate[] // M2-A F001：候选池反向关系

  @@unique([tenantId, canonicalHandle]) // F004 幂等 upsert
  @@index([tenantId])
  @@index([platform])
}

/// 五环节游标（M1-A-BRIEF F003 / D5）。取值与 `lib/agent/stage-routing.ts` 的 `Stage`
/// TS 类型逐字一致——那边是 URL `?env=` 与路由层的真相，这里是 DB 层的完整性约束，两处必须同步。
enum Stage {
  brief
  match
  reach
  delivery
  insight
}

/// 项目：五环节的唯一容器（D22）。M1-A-BRIEF F003 补齐 brief 纵线所需领域字段。
/// EXTENSION POINT：随业务真实形态充实，本批不预测焊死。
model Project {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique
  tenantId  String
  name      String
  owner     String? // D29 分工标记
  createdAt DateTime @default(now())

  // ── M1-A-BRIEF F003（D5）。全部 nullable 或带默认值：expand-contract 迁移的硬要求，
  //    保证回滚到上一个 IMAGE_TAG 时旧代码读不到新列也不崩（D12）。
  gameId      String? // mock 的 game 是裸字符串，此处升为关联
  goal        Json? // 形状见 D6 + src/lib/data/schemas/project.ts（不含预算）
  budgetTotal Decimal? @db.Decimal(14, 2) // 金额用 Decimal 不用 Float（精度）。
  //                    显式定精度：Prisma 默认 Decimal(65,30) 是通用数值口径，
  //                    给货币用 30 位小数既无意义又占空间。14,2 = 上限 9,999 亿 + 分位。
  currency    String? // ISO 4217，如 USD
  market      String? // mock 在用（projects.ts:36-81），目标态清单未列，此处补
  cur         Stage    @default(brief) // 当前环节
  maxReached  Stage    @default(brief) // 历史最远解锁位（D2 双值，支持 cur 回退）

  // 不加 status 列（D5：architecture.md:462 列了它但未定义取值语义，加语义未定的字段是负债）
  // 不加 health 列（D6：它是 health.compute 的产物，建列 = 把计算值固化成可漂移的第二真相，违反 DP-6）

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  game   Game?  @relation(fields: [gameId], references: [id], onDelete: SetNull)

  matchPlans      MatchPlan[] // M2-A F001：组合方案反向关系
  matchCandidates MatchCandidate[] // M2-A F001：候选池反向关系

  @@index([tenantId])
  @@index([gameId])
}

/// 游戏 / 知识库实体。M1-D-KNOWLEDGE F001：接上素材（Material）与知识（GameKnowledge）两平面。
/// EXTENSION POINT：其余知识库领域字段随业务充实。
model Game {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique
  tenantId  String
  name      String
  owner     String? // D29 分工标记
  createdAt DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  Project[] // M1-A-BRIEF F003：Project.gameId 的反向关系
  materials Material[] // M1-D F001：Game 1—N Material（architecture §7.6）
  knowledge GameKnowledge[] // M1-D F001：Game 1—N GameKnowledge

  @@index([tenantId])
}

// ───────────────────────── 游戏知识平面（M1-D-KNOWLEDGE F001，architecture §7.6）─────────────────────────

/// 素材类型（architecture §7.6 六值枚举）。video 本批仅存元数据不解析（P6：落库即 failed + parseError 明示）。
enum MaterialType {
  lore
  art
  gameplay_doc
  review
  data
  video
}

/// 解析状态机 ⑤（architecture §5.3）：pending → parsing → parsed / failed；failed 可重试回 parsing。
/// D20：状态机类必须配变异测试（tests/unit，F003）。
enum ParseStatus {
  pending
  parsing
  parsed
  failed
}

/// 上传素材（M1-D F001/F002）。文件本体落本地盘 docker 卷（U2），storageRef = 卷内相对路径；
/// 表只存元数据。gameId 真 FK（沿 Project.gameId 先例，Game 1—N Material）。
model Material {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String
  gameId   String

  type       MaterialType
  source     String? // 来源（官方 / 第三方 / 投放后台 / 你上传）
  fileName   String // 原始文件名（展示用；落盘名经白名单化，见 storageRef）
  storageRef String // MATERIALS_DIR 内相对路径：{gameId}/{cuid}-{safeName}
  mimeType   String
  sizeBytes  Int

  parseStatus ParseStatus @default(pending)
  parseError  String? // failed 时明示原因（D2 诚实降级，不静默）
  parsedAt    DateTime?

  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([gameId])
}

/// 知识三类 kind（architecture §7.6）。下游消费映射（FR-8.4.8）：
/// audience→匹配 · selling_point→触达 · compliance_redline→合规；strategy 三类全量（F005 ⑤层注入）。
enum KnowledgeKind {
  selling_point
  audience
  compliance_redline
}

/// 解析产物（M1-D F001/F003）。版本链 ⑥（architecture §5.3）：重解析不物理删——新条目落库、
/// 旧条目 supersededById 指向新条目（FR-11.11），读取恒取链头（supersededById IS NULL）。
/// sourceMaterialIds[] 软引用 N—N Material（D13 先例，不强 FK）：非空即知识溯源，空则非法
/// （FR-11.9，应用层 zod 校验——schemas/knowledge.ts）。
model GameKnowledge {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String
  gameId   String

  kind              KnowledgeKind
  content           String // 人类可读知识文本
  structured        Json? // 按 kind 定型的结构化载荷（zod 见 schemas/knowledge.ts，脏数据读时降级）
  sourceMaterialIds String[] // 溯源 Material.id 列表（软引用；FR-11.9 非空由应用层保证）
  confidence        Float? // 0-1（LLM 自报，保守下限原则展示为 ai_estimate 档）
  generatedBy       String  @default("strategy") // 解析人格（PRD §9.2：策略 Agent）
  supersededById    String? // → GameKnowledge.id（软引用；null = 链头）

  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([gameId, kind]) // 链头读取热路径：WHERE gameId+kind AND supersededById IS NULL
}

// ───────────────────────── 匹配平面（M2-A-MATCH F001，architecture §5.2 :464-466）─────────────────────────

/// 组合方案状态机（architecture §5.3 →reach 守卫判据）。
/// D20：draft → approved（单选：同项目其余 draft → superseded）/ draft → superseded；
/// approved 永不动（审计链，P4）——流转逻辑落 F003/F004，须配变异测试。
enum MatchPlanStatus {
  draft
  approved
  superseded
}

/// 候选裁定三态（「待你裁定」表）。pending → kept / dropped 由人工裁定（写入口归 P8 后续批）；
/// 刷新 upsert 不得把 kept/dropped 回退为 pending（P4，F003 变异测试）。
enum CandidateVerdict {
  pending
  kept
  dropped
}

/// 组合方案（M2-A F001）。批准 = internal 事件（D16 语义：选了就生效，不产生 PendingAction）。
/// metrics Json 形状 = {reachTotal:number|null, budgetUsd:number|null(P6 恒 null),
/// risk:'low'|'mid'|'high'|null, people:number}——zod 见 schemas/match.ts（读侧宽松降级 D2）。
model MatchPlan {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  projectId   String
  name        String
  metrics     Json // 展示指标聚合（形状见上；脏数据读时降级 null）
  rationale   String // 组合推荐理由（人类可读）
  recommended Boolean         @default(false)
  status      MatchPlanStatus @default(draft)
  approvedBy  String? // 批准人（单角色 dev：'operator'）
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kols    PlanKol[]

  @@index([tenantId])
  @@index([projectId, status]) // 热路径：现行组合读取（WHERE projectId AND status）
}

/// 组合成员（M2-A F001）。reasons[] = 可解释依据必带——DB 层 String[] 无非空约束，
/// 写侧由应用层 zod 把关（schemas/match.ts assertPlanKolReasons，沿 FR-11.9 先例）。
model PlanKol {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  planId     String
  kolId      String
  matchScore Float // matchScore.compute 产物（0-1）
  reasons    String[] // 可解释依据（空则非法，写侧 zod 校验）

  createdAt DateTime @default(now())

  plan MatchPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  kol  Kol       @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId]) // 热路径：组内成员读取
  @@index([kolId])
}

/// 匹配候选（M2-A F001）。「待你裁定」：存疑原因 + 初判，不显裸分（architecture :466）。
/// scorePending=true = 受众数据缺失降级纯向量分（FR-11.6），显示层「待核」（裁决 #2）。
model MatchCandidate {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  projectId    String
  kolId        String
  verdict      CandidateVerdict @default(pending)
  doubts       String[]         @default([]) // 存疑原因（规则化生成，F003）
  preJudge     String // 初判三态展示串：'高' / '中' / '?'
  matchScore   Float? // matchScore.compute 产物；null 仅当 embedding 缺失（P2 定案）
  scorePending Boolean          @default(false) // true = 降级纯向量分 → 显示「待核」

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kol     Kol     @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@unique([projectId, kolId]) // 幂等刷新键（F003 upsert）
  @@index([tenantId])
  @@index([kolId])
}

// ───────────────────────── 运行时表（闸门 / 留痕 / 交接）─────────────────────────

enum PendingActionStatus {
  pending
  confirmed
  executed
}

/// AI→人闸门落点（F009）。最小三态；outbound 动作停在确认前的待办。
/// 完整 7 态 + OutboundAttempt / reconciliation → M3。
model PendingAction {
  id                    String              @id @default(cuid())
  tenantId              String
  kind                  String
  toolName              String
  payloadHash           String
  inputJson             Json? // 工具入参（F009：人确认后据此执行；payloadHash 绑定防篡改）
  harmJson              Json // harm 结构体（F009 单一 zod：动作/对象/金额/不可逆/证据/过期）
  status                PendingActionStatus @default(pending)
  confirmationTokenHash String? // 只存 hash（F009）
  expiresAt             DateTime?
  createdAt             DateTime            @default(now())

  // ── M1-C F002（D-A）。今天页雷达接真的前置：待办要能指回「哪个项目、哪个人格」。
  //    nullable expand 迁移（回滚安全）；创建点只填不判，历史行 null 合法。
  //    软引用不强 FK（同 OperationLog.projectId D13 先例，单租户 dev）。
  projectId String? // 来源 ToolContext.projectId
  agentId   String? // 提案人格（雷达深链经 STAGE_AGENT 反查环节）

  @@index([tenantId])
  @@index([status])
}

enum OperationLogKind {
  auto
  gate
  block
  irrev
}

/// 留痕落点（append-only：只 INSERT，无 updatedAt）。闸门确认 / 拒绝 / 不可逆执行均追加一条（F009）。
model OperationLog {
  id        String           @id @default(cuid())
  tenantId  String
  kind      OperationLogKind
  actor     String?
  summary   String?
  ref       String? // → PendingAction.id。语义单一，不得挪作他用（D13）
  createdAt DateTime         @default(now())

  // ── M1-A-BRIEF F003（D13）。开工前审计发现 D10 的事实前提有误：有 projectId 的是
  //    Handoff，OperationLog 并没有，且全表无任何 JSON 载荷列。用户授权本批以 expand 迁移补两列。
  //    北极星「操盘手杠杆」= 环节推进事件计数 × 周活（architecture.md:1695），
  //    而 ADR-21 明确不建 EventStore —— 不落这里就没有任何地方存，且永久不可补录。
  projectId   String? // 软引用（同 Handoff.projectId 先例，单租户下不强 FK）
  payloadJson Json? // 结构化载荷，如环节推进的 {from,to,maxReachedBefore,maxReachedAfter}

  @@index([tenantId])
  @@index([kind])
  @@index([projectId])
}

/// 多 Agent 编排交接落点（F006，架构稿 §5.4 信封格式）。
/// 接收方按自身 scope 重读数据、不信任发送方携带的结论（F006 语义）。
/// EXTENSION POINT：具体载荷（messagesJson 结构）随 M1-M4 真实 handoff 链充实。
model Handoff {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String? // 交接归属的项目（软引用，projectId 索引；单租户下不强 FK）
  fromAgent    String
  toAgent      String
  artifactType String?
  artifactRef  String?
  summary      String?
  messagesJson Json?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([projectId])
}
