// AGENT-FOUNDATION F002 — 核心 schema（单角色）+ 运行时表（闸门 + 交接）
//
// 设计契约（权威：docs/specs/AGENT-FOUNDATION-spec.md §F002 + PRD §11 + 架构稿 §7.2）：
// - 单租户（D4）：Tenant 占位，硬编码 dev tenant；真实认证 / 多租户 RLS 留 M5（本批不建 RLS policy）
// - 单角色（D26）：User 无 role / scope / 权限字段
// - D29：业务实体带 owner 标记（String? = Leo/Ada/Kai）——是分工不是权限，非枚举非权限
// - D15：Kol 预留数据层字段契约位（audienceDemo/credibility/brandSafety/dataSource/fieldProvenance），本批 nullable 不填充
// - D3：pgvector 经自定义 SQL migration（CREATE EXTENSION IF NOT EXISTS vector），不用 Prisma postgresqlExtensions 预览开关；
//       Kol.embedding = Unsupported("vector(1024)")（Prisma 无原生 vector 类型，向量读写走 raw SQL，F004/F005）
// - D-INTEROP（§3.3）：核心实体（Kol/Project/Game/Tenant）带稳定对外标识 publicId/slug——为 GEO / 外部 agent 友好留插座；
//       fieldProvenance/dataSource 兼作对外可信层（provenance）。JSON-LD / GEO 具体字段 = EXTENSION POINT，本批不实装、不猜字段。
// - 三运行时表：PendingAction（F009 闸门落点）/ OperationLog（留痕）/ Handoff（F006 编排交接落点，架构稿 §5.4）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── 租户 / 用户（单租户 · 单角色）─────────────────────────

/// 租户占位表。本批单租户（硬编码 dev tenant），真实多租户 / RLS → M5。
model Tenant {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique // D-INTEROP 人类可读稳定标识
  name      String?
  createdAt DateTime @default(now())

  users    User[]
  kols     Kol[]
  projects Project[]
  games    Game[]
}

/// 单 dev 用户。D26：无 role / scope / 权限字段（三角色作废）。
model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ───────────────────────── 核心业务实体 ─────────────────────────

/// KOL 核心实体。含向量列 + D15 字段契约位（nullable）+ D29 owner + D-INTEROP 稳定标识。
model Kol {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识（未来 MCP / GEO 引用锚点）
  tenantId String

  /// F004 幂等 upsert 键：规范化后的唯一 handle
  canonicalHandle String

  // 核心字段（F004 CSV seed 填充；多数 nullable 以容忍 CSV 差异）
  displayName    String?
  platform       String? // youtube / twitch / tiktok / instagram
  handle         String?
  profileUrl     String?
  avatarUrl      String?
  country        String?
  language       String?
  followers      Int?
  avgViews       Int?
  engagementRate Float?
  categories     String[] @default([])
  bio            String?

  /// M3-A F001（P3）：联系邮箱——人工录入（CreatorDrawer 抽屉入口，F007），不做自动采集；
  /// 来源在 fieldProvenance 标 user_input。真实 KOL 行不得写入测试地址（P1）。
  contactEmail String?

  /// pgvector 向量列（bge-m3 1024 维，D3）。Unsupported → 读写走 raw SQL（F004 灌向量 / F005 cosine 检索）。
  embedding Unsupported("vector(1024)")?

  // ── D15 数据层字段契约位（本批 nullable 不填充；让数据层与应用层解耦）──
  // 兼作 D-INTEROP provenance 对外可信层（GEO 时代 AI 引擎最看重「有出处、可信」）。
  audienceDemo    Json? // 受众画像
  credibility     Json? // 可信度评估（结构留扩展点，第三方评估 API → M5）
  brandSafety     Json? // 品牌安全评估
  dataSource      String? // 数据来源（架构稿 §7.5：按真实证据填写）
  fieldProvenance Json? // 逐字段出处（provenance）

  /// D29 分工标记（Leo/Ada/Kai）——是分工不是权限，非枚举非权限。
  owner String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planKols        PlanKol[] // M2-A F001：入选组合的反向关系
  matchCandidates MatchCandidate[] // M2-A F001：候选池反向关系
  outreachThreads OutreachThread[] // M3-A F001：触达线程反向关系
  deals           Deal[] // M3-B F001：交易反向关系

  @@unique([tenantId, canonicalHandle]) // F004 幂等 upsert
  @@index([tenantId])
  @@index([platform])
}

/// 五环节游标（M1-A-BRIEF F003 / D5）。取值与 `lib/agent/stage-routing.ts` 的 `Stage`
/// TS 类型逐字一致——那边是 URL `?env=` 与路由层的真相，这里是 DB 层的完整性约束，两处必须同步。
enum Stage {
  brief
  match
  reach
  delivery
  insight
}

/// 项目：五环节的唯一容器（D22）。M1-A-BRIEF F003 补齐 brief 纵线所需领域字段。
/// EXTENSION POINT：随业务真实形态充实，本批不预测焊死。
model Project {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique
  tenantId  String
  name      String
  owner     String? // D29 分工标记
  createdAt DateTime @default(now())

  // ── M1-A-BRIEF F003（D5）。全部 nullable 或带默认值：expand-contract 迁移的硬要求，
  //    保证回滚到上一个 IMAGE_TAG 时旧代码读不到新列也不崩（D12）。
  gameId      String? // mock 的 game 是裸字符串，此处升为关联
  goal        Json? // 形状见 D6 + src/lib/data/schemas/project.ts（不含预算）
  budgetTotal Decimal? @db.Decimal(14, 2) // 金额用 Decimal 不用 Float（精度）。
  //                    显式定精度：Prisma 默认 Decimal(65,30) 是通用数值口径，
  //                    给货币用 30 位小数既无意义又占空间。14,2 = 上限 9,999 亿 + 分位。
  currency    String? // ISO 4217，如 USD
  market      String? // mock 在用（projects.ts:36-81），目标态清单未列，此处补
  cur         Stage    @default(brief) // 当前环节
  maxReached  Stage    @default(brief) // 历史最远解锁位（D2 双值，支持 cur 回退）

  // 不加 status 列（D5：architecture.md:462 列了它但未定义取值语义，加语义未定的字段是负债）
  // 不加 health 列（D6：它是 health.compute 的产物，建列 = 把计算值固化成可漂移的第二真相，违反 DP-6）

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  game   Game?  @relation(fields: [gameId], references: [id], onDelete: SetNull)

  matchPlans      MatchPlan[] // M2-A F001：组合方案反向关系
  matchCandidates MatchCandidate[] // M2-A F001：候选池反向关系
  outreachThreads OutreachThread[] // M3-A F001：触达线程反向关系
  deals           Deal[] // M3-B F001：交易反向关系

  @@index([tenantId])
  @@index([gameId])
}

/// 游戏 / 知识库实体。M1-D-KNOWLEDGE F001：接上素材（Material）与知识（GameKnowledge）两平面。
/// EXTENSION POINT：其余知识库领域字段随业务充实。
model Game {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(cuid()) // D-INTEROP 稳定对外标识
  slug      String?  @unique
  tenantId  String
  name      String
  owner     String? // D29 分工标记
  createdAt DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  Project[] // M1-A-BRIEF F003：Project.gameId 的反向关系
  materials Material[] // M1-D F001：Game 1—N Material（architecture §7.6）
  knowledge GameKnowledge[] // M1-D F001：Game 1—N GameKnowledge

  @@index([tenantId])
}

// ───────────────────────── 游戏知识平面（M1-D-KNOWLEDGE F001，architecture §7.6）─────────────────────────

/// 素材类型（architecture §7.6 六值枚举）。video 本批仅存元数据不解析（P6：落库即 failed + parseError 明示）。
enum MaterialType {
  lore
  art
  gameplay_doc
  review
  data
  video
}

/// 解析状态机 ⑤（architecture §5.3）：pending → parsing → parsed / failed；failed 可重试回 parsing。
/// D20：状态机类必须配变异测试（tests/unit，F003）。
enum ParseStatus {
  pending
  parsing
  parsed
  failed
}

/// 上传素材（M1-D F001/F002）。文件本体落本地盘 docker 卷（U2），storageRef = 卷内相对路径；
/// 表只存元数据。gameId 真 FK（沿 Project.gameId 先例，Game 1—N Material）。
model Material {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String
  gameId   String

  type       MaterialType
  source     String? // 来源（官方 / 第三方 / 投放后台 / 你上传）
  fileName   String // 原始文件名（展示用；落盘名经白名单化，见 storageRef）
  storageRef String // MATERIALS_DIR 内相对路径：{gameId}/{cuid}-{safeName}
  mimeType   String
  sizeBytes  Int

  parseStatus ParseStatus @default(pending)
  parseError  String? // failed 时明示原因（D2 诚实降级，不静默）
  parsedAt    DateTime?

  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([gameId])
}

/// 知识三类 kind（architecture §7.6）。下游消费映射（FR-8.4.8）：
/// audience→匹配 · selling_point→触达 · compliance_redline→合规；strategy 三类全量（F005 ⑤层注入）。
enum KnowledgeKind {
  selling_point
  audience
  compliance_redline
}

/// 解析产物（M1-D F001/F003）。版本链 ⑥（architecture §5.3）：重解析不物理删——新条目落库、
/// 旧条目 supersededById 指向新条目（FR-11.11），读取恒取链头（supersededById IS NULL）。
/// sourceMaterialIds[] 软引用 N—N Material（D13 先例，不强 FK）：非空即知识溯源，空则非法
/// （FR-11.9，应用层 zod 校验——schemas/knowledge.ts）。
model GameKnowledge {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String
  gameId   String

  kind              KnowledgeKind
  content           String // 人类可读知识文本
  structured        Json? // 按 kind 定型的结构化载荷（zod 见 schemas/knowledge.ts，脏数据读时降级）
  sourceMaterialIds String[] // 溯源 Material.id 列表（软引用；FR-11.9 非空由应用层保证）
  confidence        Float? // 0-1（LLM 自报，保守下限原则展示为 ai_estimate 档）
  generatedBy       String        @default("strategy") // 解析人格（PRD §9.2：策略 Agent）
  supersededById    String? // → GameKnowledge.id（软引用；null = 链头）

  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([gameId, kind]) // 链头读取热路径：WHERE gameId+kind AND supersededById IS NULL
}

// ───────────────────────── 匹配平面（M2-A-MATCH F001，architecture §5.2 :464-466）─────────────────────────

/// 组合方案状态机（architecture §5.3 →reach 守卫判据）。
/// D20：draft → approved（单选：同项目其余 draft → superseded）/ draft → superseded；
/// approved 永不动（审计链，P4）——流转逻辑落 F003/F004，须配变异测试。
enum MatchPlanStatus {
  draft
  approved
  superseded
}

/// 候选裁定三态（「待你裁定」表）。pending → kept / dropped 由人工裁定（写入口归 P8 后续批）；
/// 刷新 upsert 不得把 kept/dropped 回退为 pending（P4，F003 变异测试）。
enum CandidateVerdict {
  pending
  kept
  dropped
}

/// 组合方案（M2-A F001）。批准 = internal 事件（D16 语义：选了就生效，不产生 PendingAction）。
/// metrics Json 形状 = {reachTotal:number|null, budgetUsd:number|null(P6 恒 null),
/// risk:'low'|'mid'|'high'|null, people:number}——zod 见 schemas/match.ts（读侧宽松降级 D2）。
model MatchPlan {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  projectId   String
  name        String
  metrics     Json // 展示指标聚合（形状见上；脏数据读时降级 null）
  rationale   String // 组合推荐理由（人类可读）
  recommended Boolean         @default(false)
  status      MatchPlanStatus @default(draft)
  approvedBy  String? // 批准人（单角色 dev：'operator'）
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kols    PlanKol[]

  @@index([tenantId])
  @@index([projectId, status]) // 热路径：现行组合读取（WHERE projectId AND status）
}

/// 组合成员（M2-A F001）。reasons[] = 可解释依据必带——DB 层 String[] 无非空约束，
/// 写侧由应用层 zod 把关（schemas/match.ts assertPlanKolReasons，沿 FR-11.9 先例）。
model PlanKol {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  planId     String
  kolId      String
  matchScore Float // matchScore.compute 产物（0-1）
  reasons    String[] // 可解释依据（空则非法，写侧 zod 校验）

  createdAt DateTime @default(now())

  plan MatchPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  kol  Kol       @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId]) // 热路径：组内成员读取
  @@index([kolId])
}

/// 匹配候选（M2-A F001）。「待你裁定」：存疑原因 + 初判，不显裸分（architecture :466）。
/// scorePending=true = 受众数据缺失降级纯向量分（FR-11.6），显示层「待核」（裁决 #2）。
model MatchCandidate {
  id       String @id @default(cuid())
  publicId String @unique @default(cuid()) // D-INTEROP 稳定对外标识
  tenantId String

  projectId    String
  kolId        String
  verdict      CandidateVerdict @default(pending)
  doubts       String[]         @default([]) // 存疑原因（规则化生成，F003）
  preJudge     String // 初判三态展示串：'高' / '中' / '?'
  matchScore   Float? // matchScore.compute 产物；null 仅当 embedding 缺失（P2 定案）
  scorePending Boolean          @default(false) // true = 降级纯向量分 → 显示「待核」

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kol     Kol     @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@unique([projectId, kolId]) // 幂等刷新键（F003 upsert）
  @@index([tenantId])
  @@index([kolId])
}

// ───────────────────────── 触达平面（M3-A-REACH-CRM F001，spec §4 / architecture :467-470）─────────────────────────

/// CRM 五态（architecture :491）。真相由 crmInfer.status 纯函数从 messages+signals+quotes 推断（F005），
/// 本列是推断结果的物化缓存；confirmed 仅由 quote.committed 推出，manual_override 不可断言（U4）。
enum ReachStatus {
  pending_send
  sent
  replied
  negotiating
  confirmed
}

/// 触达消息方向。sent 必带 gateLogId（闸门留痕，:468）；inbound 本批仅 webhook 投递状态事件承载（P2），
/// 真入站收信 → M3-B+。
enum MessageDirection {
  draft
  sent
  inbound
}

/// 报价状态。committed 必经 commit_quote 闸门（gateLogId 必非空）；不可人工覆盖（U4）。
enum QuoteStatus {
  proposed
  committed
  rejected
}

/// 触达线程（M3-A F001）。一个创作者 = 一段关系 = 一个 thread（architecture :467）。
model OutreachThread {
  id       String @id @default(cuid())
  tenantId String

  projectId    String
  kolId        String
  status       ReachStatus @default(pending_send)
  owner        String      @default("reach") // D29 分工标记
  lastSignalAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kol     Kol     @relation(fields: [kolId], references: [id], onDelete: Cascade)

  messages OutreachMessage[]
  quotes   Quote[]

  @@unique([projectId, kolId]) // 一人一线程（:467）
  @@index([tenantId])
  @@index([kolId])
}

/// 触达消息（M3-A F001）。gateLogId = PendingAction.id 软引用（D13 先例，语义单一）；
/// direction=sent 时必非空（应用层保证，:468）。providerMessageId = Resend 消息 id（幂等查重，P6）。
model OutreachMessage {
  id       String @id @default(cuid())
  tenantId String

  threadId          String
  direction         MessageDirection
  subject           String?
  body              String
  language          String?
  gateLogId         String? // → PendingAction.id（软引用；sent 必非空）
  providerMessageId String?
  sentAt            DateTime?

  createdAt DateTime @default(now())

  thread OutreachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([threadId])
}

/// 报价（M3-A F001）。金额用 Decimal(14,2)（沿 Project.budgetTotal 先例）；
/// committed 时 budgetUsd 回填至 PlanKol/展示层（P8，F006）。
model Quote {
  id       String @id @default(cuid())
  tenantId String

  threadId         String
  amount           Decimal     @db.Decimal(14, 2)
  currency         String // ISO 4217，如 USD
  deliverablesJson Json
  scope            String?
  status           QuoteStatus @default(proposed)
  gateLogId        String? // → PendingAction.id（软引用；committed 必非空）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread OutreachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([threadId])
}

/// 信号（M3-A F001）。领域事件承载（ADR-21 不建 EventStore：Signal + OperationLog + 状态列）。
/// append-only 事件表：kolId/projectId/threadId 均软引用不强 FK（同 OperationLog D13 先例）；
/// externalId @unique 防重（webhook 同事件重放只落一行，:470）。
/// type 取值：email_delivery_status（F004 webhook）/ manual_override（F009 有限覆盖，仅可断言
/// sent/replied/negotiating——U4）；source 取值：resend / user 等。
model Signal {
  id       String @id @default(cuid())
  tenantId String

  type        String
  source      String
  externalId  String   @unique // 防重键
  kolId       String? // 软引用
  projectId   String? // 软引用
  threadId    String? // 软引用 → OutreachThread.id
  payloadJson Json
  detectedAt  DateTime

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([threadId])
}

// ───────────────────────── 交付平面（M3-B-DELIVERY F001，spec §4 / architecture :471-474）─────────────────────────
//
// RLS：本项目单租户 dev 不建 RLS policy（AGENT-FOUNDATION D4，见文件头；既有 17 表同口径），
// M5 真实认证时统一补。本批四表沿同一例外口径——理由记录在 spec §4（database-patterns §8 要求的显式登记）。

/// Deal 资金生命周期状态机（architecture :507 六态 + blocked/defaulted 分支）。
/// 流转由 `domain/deal-advance.ts` 的 dealAdvance 纯函数承载（F003）：
/// negotiating → signed → escrowed → delivering → completed；blocked 可恢复；defaulted 终态。
/// D20：状态机类必须配变异测试。
enum DealStatus {
  negotiating
  signed
  escrowed
  delivering
  completed
  blocked
  defaulted
}

/// 交付条件五类（P3）——与 V7 台账五列一一对应（architecture :472 明文）。
enum DeliverableKind {
  content
  key
  contract
  escrow
  ad_disclosure
}

/// 交付条件三态 + 未开始（P3）。`na` = 不适用（如无 key 交付的合作），
/// **不得压成二态**（V7 §2.3 硬要求）；`na` 不计入 ready 判定（F002 deliveryCheck）。
enum DeliverableStatus {
  pending
  met
  missing
  na
}

/// key 分发二态（P8）。distributed 必带 gateLogId（闸门留痕）。
enum GameKeyStatus {
  reserved
  distributed
}

/// 放款三态（P1）。released 必带 gateLogId；**零真实资金动作**——release 走 mock EscrowPartner
/// （F004），本表只记录状态与依据，不碰真钱（architecture §1 资金边界）。
enum PayoutStatus {
  prepared
  released
  blocked
}

/// 交易（M3-B F001）。由 committed Quote 在 commit_quote 执行事务内生成（P2，F003）——
/// 「有 committed quote 必有 Deal」是 →delivery 守卫判据（architecture §5.3① :488）的数据前提。
/// quoteId 软引用不强 FK（同 OperationLog.projectId D13 先例）。
model Deal {
  id       String @id @default(cuid())
  tenantId String

  projectId   String
  kolId       String
  quoteId     String? // → Quote.id（软引用；来源报价）
  termsJson   Json // 金额/币种/交付物/范围快照（取自 Quote，冻结不随 Quote 变）
  contractRef String? // 外部电子签单号（P4 人工登记）
  escrowRef   String? // 外部托管单号（P4 人工登记）
  status      DealStatus @default(negotiating)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kol     Kol     @relation(fields: [kolId], references: [id], onDelete: Cascade)

  deliverables Deliverable[]
  gameKeys     GameKey[]
  payouts      Payout[]

  @@unique([projectId, kolId]) // 一人一 Deal（沿 OutreachThread :467 先例）
  @@index([tenantId])
  @@index([kolId])
}

/// 交付条件行（M3-B F001）。Deal 创建时按 Quote.deliverables 与合作形态生成五条（P3）：
/// content/contract/escrow/ad_disclosure 恒必需；key 视是否含 key 交付 → required 或 na。
/// required=false 且 status=na 的行不计入 ready（F002 deliveryCheck 的诚实语义）。
model Deliverable {
  id       String @id @default(cuid())
  tenantId String

  dealId      String
  kind        DeliverableKind
  status      DeliverableStatus @default(pending)
  required    Boolean           @default(true)
  evidenceRef String? // 证据引用（稿件链接 / 披露截图 / 单号）
  verifiedBy  String? // 人工核验者（单角色 dev：'operator'）
  note        String? // V7 台账 🔒 附注条件渲染的数据源

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, kind]) // 五条件每类一行
  @@index([tenantId])
  @@index([dealId])
}

/// 游戏 key（M3-B F001，P8）。keyRef 存**引用不存明文 key 值**——key 池由人工登记
/// （POST /api/delivery/deals/[id]/keys，F008）；不做 key 生成 / 采购 / 平台对接。
model GameKey {
  id       String @id @default(cuid())
  tenantId String

  dealId        String
  keyRef        String // 引用（如外部 key 池条目号）；明文 key 值不得入库
  status        GameKeyStatus @default(reserved)
  distributedAt DateTime?
  gateLogId     String? // → PendingAction.id（软引用；distributed 必非空）

  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dealId])
}

/// 放款（M3-B F001，P1/P6）。payee = 收款方（创作者），**不是角色**（P7：三角色属作废层 D26-D29）。
/// released 必带 gateLogId（软引用 → PendingAction.id）；执行前服务端重跑 deliveryCheck，
/// ready=false 一律拒（FR-8.2.4.2 无绕过入口）。金额 Decimal(14,2)（沿 Quote.amount 先例）。
model Payout {
  id       String @id @default(cuid())
  tenantId String

  dealId     String
  payee      String
  amount     Decimal      @db.Decimal(14, 2)
  currency   String // ISO 4217，如 USD
  basis      String // 依据摘要（合同 + 托管 + 披露证据引用）
  status     PayoutStatus @default(prepared)
  gateLogId  String? // → PendingAction.id（软引用；released 必非空）
  releasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dealId])
}

// ───────────────────────── 运行时表（闸门 / 留痕 / 交接）─────────────────────────

/// 闸门 7 态（M3-A F001 expand：加值不删值）。流转（§9.3.2 两步票据，F002）：
/// pending → confirmed（confirm 签票）→ executing → executed / failed（execute 消费票）；
/// pending → rejected（人拒绝）/ expired（超时）。原子条件 UPDATE 消并发双确认（R15）。
enum PendingActionStatus {
  pending
  confirmed
  executing
  executed
  failed
  rejected
  expired
}

/// AI→人闸门落点（F009 三态 → M3-A F001/F002 升级两步票据 7 态）。outbound 动作停在确认前的待办。
/// 两步票据（§9.3.2）：confirm 校验 confirmationToken → 签发一次性执行票（票明文仅 confirm 响应
/// 出现一次，DB 只存 ticketHash，ADR-25 不变量）→ execute 消费票（原子条件 UPDATE，过期/重放拒）。
/// OutboundAttempt / reconciliation → M3-B+。
model PendingAction {
  id                    String              @id @default(cuid())
  tenantId              String
  kind                  String
  toolName              String
  payloadHash           String
  inputJson             Json? // 工具入参（F009：人确认后据此执行；payloadHash 绑定防篡改）
  harmJson              Json // harm 结构体（F009 单一 zod：动作/对象/金额/不可逆/证据/过期）
  status                PendingActionStatus @default(pending)
  confirmationTokenHash String? // 只存 hash（F009）
  expiresAt             DateTime?
  createdAt             DateTime            @default(now())

  // ── M3-A F001（§9.3.2 两步票据新列，nullable expand 迁移，回滚安全）──
  ticketHash      String? // 执行票 hash（confirm 签发；明文不落库）
  ticketExpiresAt DateTime? // 执行票过期时刻（短 TTL）
  ticketUsedAt    DateTime? // 消费时刻（原子条件 UPDATE 的重放挡板）
  decidedAt       DateTime? // 人裁决时刻（confirm / reject 共用）

  // ── M1-C F002（D-A）。今天页雷达接真的前置：待办要能指回「哪个项目、哪个人格」。
  //    nullable expand 迁移（回滚安全）；创建点只填不判，历史行 null 合法。
  //    软引用不强 FK（同 OperationLog.projectId D13 先例，单租户 dev）。
  projectId String? // 来源 ToolContext.projectId
  agentId   String? // 提案人格（雷达深链经 STAGE_AGENT 反查环节）

  @@index([tenantId])
  @@index([status])
}

enum OperationLogKind {
  auto
  gate
  block
  irrev
}

/// 留痕落点（append-only：只 INSERT，无 updatedAt）。闸门确认 / 拒绝 / 不可逆执行均追加一条（F009）。
model OperationLog {
  id        String           @id @default(cuid())
  tenantId  String
  kind      OperationLogKind
  actor     String?
  summary   String?
  ref       String? // → PendingAction.id。语义单一，不得挪作他用（D13）
  createdAt DateTime         @default(now())

  // ── M1-A-BRIEF F003（D13）。开工前审计发现 D10 的事实前提有误：有 projectId 的是
  //    Handoff，OperationLog 并没有，且全表无任何 JSON 载荷列。用户授权本批以 expand 迁移补两列。
  //    北极星「操盘手杠杆」= 环节推进事件计数 × 周活（architecture.md:1695），
  //    而 ADR-21 明确不建 EventStore —— 不落这里就没有任何地方存，且永久不可补录。
  projectId   String? // 软引用（同 Handoff.projectId 先例，单租户下不强 FK）
  payloadJson Json? // 结构化载荷，如环节推进的 {from,to,maxReachedBefore,maxReachedAfter}

  @@index([tenantId])
  @@index([kind])
  @@index([projectId])
}

/// 多 Agent 编排交接落点（F006，架构稿 §5.4 信封格式）。
/// 接收方按自身 scope 重读数据、不信任发送方携带的结论（F006 语义）。
/// EXTENSION POINT：具体载荷（messagesJson 结构）随 M1-M4 真实 handoff 链充实。
model Handoff {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String? // 交接归属的项目（软引用，projectId 索引；单租户下不强 FK）
  fromAgent    String
  toAgent      String
  artifactType String?
  artifactRef  String?
  summary      String?
  messagesJson Json?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([projectId])
}
